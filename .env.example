# Copy this file to .env and fill only the channels you want to use.

ATTENDANCE_THRESHOLD_PERCENT=75
NOTIFICATION_DRY_RUN=false

# Required for receiver OK links. Use a public URL if students open links from phones.
# Example with ngrok: https://your-id.ngrok-free.app
PUBLIC_BASE_URL=

# Email alerts through SMTP.
# For Gmail, use an app password, not your normal account password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_SENDER=your_email@gmail.com
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# SMS alerts through Twilio.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_PHONE=+10000000000
